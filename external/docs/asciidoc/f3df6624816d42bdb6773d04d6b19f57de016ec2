	   [-F <fichero> | -m <mensaje>] [--reset-author] [--allow-empty]
	   [--allow-empty-message] [--no-verify] [-e] [--author=<autor>]
	   [--date=<fecha>] [--cleanup=<modo>] [--[no-]status]
	   [-i | -o] [--pathspec-from-file=<fichero> [--pathspec-file-nul]]
